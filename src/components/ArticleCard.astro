---
import categories from '../data/categories.json';

interface Props {
  article: {
    slug: string;
    data: {
      title: string;
      description: string;
      category: string;
      heroImage: string;
      heroAlt: string;
      readingTime: number;
      datePublished: string;
    };
  };
}

const { article } = Astro.props;
const { data } = article;

// Decode category slugs to display names (e.g., "health-amp-wellness" → "Health & Wellness")
const categoryMap = Object.fromEntries(categories.map((c: { slug: string; label: string }) => [c.slug, c.label]));
const displayCategory = categoryMap[data.category] || data.category.replace(/-/g, ' ').replace(/\bamp\b/g, '&');
---

<a href={`/${data.slug || article.slug}`} class="group block bg-white rounded-lg border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
  <img
    src={data.heroImage}
    alt={data.heroAlt}
    width="400"
    height="225"
    class="w-full aspect-video object-cover bg-gray-100"
    loading="lazy"
    decoding="async"
    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
    onerror="this.onerror=null;this.src='/images/articles/placeholder.svg'"
  />
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2 text-xs text-gray-500">
      <span class="category-badge text-xs">{displayCategory}</span>
      <span>{data.readingTime} min</span>
    </div>
    <h3 class="font-heading font-semibold text-gray-900 group-hover:text-primary transition-colors line-clamp-2">
      {data.title}
    </h3>
    <p class="mt-2 text-sm text-gray-500 line-clamp-2">{data.description}</p>
  </div>
</a>
