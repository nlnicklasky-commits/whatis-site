---
interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

<section class="mt-12">
  <h2>Frequently Asked Questions</h2>
  <div class="space-y-4 not-prose">
    {items.map(item => (
      <details class="group border border-gray-200 rounded-lg">
        <summary class="cursor-pointer px-5 py-4 font-heading font-medium text-gray-900 group-open:text-blue-600 flex items-center justify-between">
          <span>{item.q}</span>
          <svg class="w-5 h-5 shrink-0 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4">
          <p class="text-gray-600 leading-relaxed">{item.a}</p>
        </div>
      </details>
    ))}
  </div>
</section>
