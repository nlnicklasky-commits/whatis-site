---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
  <nav class="p-4 bg-gray-50 rounded-lg" aria-label="Table of contents">
    <h3 class="text-sm font-heading font-semibold text-gray-500 uppercase tracking-wider mb-3">Contents</h3>
    <ul class="space-y-2 text-sm">
      {tocHeadings.map(heading => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="text-gray-600 hover:text-blue-600 transition-colors block py-0.5"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
