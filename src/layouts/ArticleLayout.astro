---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import FAQ from '../components/FAQ.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import AdSlot from '../components/AdSlot.astro';
import categories from '../data/categories.json';

const { frontmatter, headings } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://whatis.site';
const canonicalUrl = `${siteUrl}/${frontmatter.slug}`;

// Decode category slugs to display names
const categoryMap = Object.fromEntries(categories.map((c: { slug: string; label: string }) => [c.slug, c.label]));
const displayCategory = categoryMap[frontmatter.category] || frontmatter.category.replace(/-/g, ' ').replace(/\bamp\b/g, '&');
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  canonicalUrl={canonicalUrl}
  ogImage={`${siteUrl}${frontmatter.heroImage}`}
  ogType="article"
>
  <!-- Article Schema (with speakable for voice assistants / GEO) -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": canonicalUrl,
    "headline": frontmatter.title,
    "description": frontmatter.description,
    "author": { "@type": "Organization", "name": frontmatter.author || "WhatIs Editorial", "url": siteUrl },
    "publisher": {
      "@type": "Organization",
      "name": "WhatIs.site",
      "url": siteUrl,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.svg` }
    },
    "datePublished": frontmatter.datePublished,
    "dateModified": frontmatter.dateModified,
    "image": `${siteUrl}${frontmatter.heroImage}`,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "wordCount": frontmatter.wordCount,
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".prose > p:first-of-type", ".prose h2", ".prose > p:nth-of-type(2)"]
    },
    "isAccessibleForFree": true,
  })} />

  <!-- FAQ Schema -->
  {frontmatter.faq?.length > 0 && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": frontmatter.faq.map((item: { q: string; a: string }) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a }
      }))
    })} />
  )}

  <AdSlot position="header-leaderboard" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs category={frontmatter.category} title={frontmatter.title} />

    <header class="mb-8">
      <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
        <a href={`/category/${frontmatter.category}`} class="category-badge hover:bg-blue-100 transition-colors">
          {displayCategory}
        </a>
        <span>{frontmatter.readingTime} min read</span>
        <time datetime={frontmatter.datePublished}>
          {new Date(frontmatter.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {frontmatter.dateModified && frontmatter.dateModified !== frontmatter.datePublished && (
          <span class="text-gray-400">
            (Updated <time datetime={frontmatter.dateModified}>
              {new Date(frontmatter.dateModified).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>)
          </span>
        )}
      </div>

      <img
        src={frontmatter.heroImage}
        alt={frontmatter.heroAlt}
        width="1200"
        height="675"
        class="w-full rounded-lg mb-8 aspect-video object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 720px"
        onerror="this.onerror=null;this.src='/images/articles/placeholder.svg'"
      />
    </header>

    <div class="lg:flex lg:gap-10">
      <!-- Sidebar TOC (desktop) -->
      <aside class="hidden lg:block lg:w-64 shrink-0">
        <div class="sticky top-8">
          <TableOfContents headings={headings} />
          <AdSlot position="sidebar-sticky" />
        </div>
      </aside>

      <!-- Article body -->
      <div class="prose prose-lg max-w-none flex-1">
        <!-- Mobile TOC -->
        <details class="lg:hidden mb-8 bg-gray-50 rounded-lg p-4">
          <summary class="cursor-pointer font-heading font-semibold text-gray-700">Table of Contents</summary>
          <nav class="mt-3">
            <ul class="space-y-2 text-sm list-none pl-0">
              {headings.filter((h: any) => h.depth === 2 || h.depth === 3).map((heading: any) => (
                <li class={heading.depth === 3 ? 'ml-4' : ''}>
                  <a href={`#${heading.slug}`} class="text-gray-600 hover:text-blue-600 no-underline">
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </details>

        <slot />

        <AdSlot position="in-content" />

        {frontmatter.faq?.length > 0 && <FAQ items={frontmatter.faq} />}

        {frontmatter.externalSources?.length > 0 && (
          <section class="mt-12">
            <h2>Further Reading</h2>
            <ul>
              {frontmatter.externalSources.map((src: { title: string; url: string }) => (
                <li>
                  <a href={src.url} target="_blank" rel="noopener noreferrer">{src.title}</a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>

    <AdSlot position="end-of-article" />

    <RelatedArticles slugs={frontmatter.relatedArticles} />
  </article>

  <AdSlot position="mobile-anchor" />
</BaseLayout>
