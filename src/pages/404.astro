---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://whatis.site';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  canonicalUrl={`${siteUrl}/404`}
>
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h1 class="font-heading text-6xl font-bold text-gray-900 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">
      That page doesn't exist — but there's plenty more to explore.
    </p>
    <a
      href="/"
      class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-heading font-medium hover:bg-blue-600 transition-colors"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
