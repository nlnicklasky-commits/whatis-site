---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import categoriesData from '../data/categories.json';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://whatis.site';

// Get 3 random popular articles for suggestions
const allArticles = await getCollection('articles');
const tier1And2 = allArticles.filter(a => a.data.tier === '1' || a.data.tier === '2');
const shuffled = tier1And2.sort(() => Math.random() - 0.5);
const suggestedArticles = shuffled.slice(0, 3);

// Get top 8 categories by article count
const categoryCounts: Record<string, number> = {};
for (const article of allArticles) {
  categoryCounts[article.data.category] = (categoryCounts[article.data.category] || 0) + 1;
}
const topCategories = categoriesData
  .map(c => ({ ...c, count: categoryCounts[c.slug] || 0 }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  canonicalUrl={`${siteUrl}/404`}
>
  <div class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h1 class="font-heading text-6xl font-bold text-gray-900 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-6">
      That page doesn't exist — but there's plenty to explore.
    </p>
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a
        href="/"
        class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-heading font-medium hover:bg-blue-600 transition-colors"
      >
        Back to Home
      </a>
      <a
        href="/categories"
        class="inline-block bg-gray-100 text-gray-700 px-6 py-3 rounded-lg font-heading font-medium hover:bg-gray-200 transition-colors"
      >
        Browse Categories
      </a>
    </div>
  </div>

  <!-- Browse by Category -->
  <section class="max-w-4xl mx-auto px-4 pb-8">
    <h2 class="font-heading text-lg font-semibold text-gray-900 mb-4 text-center">Popular Categories</h2>
    <div class="flex flex-wrap justify-center gap-2">
      {topCategories.map(cat => (
        <a
          href={`/category/${cat.slug}`}
          class="category-badge hover:bg-blue-100 transition-colors"
        >
          {cat.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Suggested Articles -->
  {suggestedArticles.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 py-8">
      <h2 class="font-heading text-lg font-semibold text-gray-900 mb-6 text-center">You Might Like</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {suggestedArticles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
