---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import categoriesData from '../data/categories.json';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://whatis.site';

const allArticles = await getCollection('articles');

// Count articles per category
const categoryCounts: Record<string, number> = {};
for (const article of allArticles) {
  const cat = article.data.category;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}

// Enrich categories with counts and sort by article count
const enrichedCategories = categoriesData
  .map(cat => ({
    ...cat,
    count: categoryCounts[cat.slug] || 0,
  }))
  .sort((a, b) => b.count - a.count);
---

<BaseLayout
  title="All Categories"
  description="Browse all categories on WhatIs.site — over 1,600 articles across technology, science, finance, philosophy, history, and more."
  canonicalUrl={`${siteUrl}/categories`}
>
  <!-- CollectionPage Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "All Categories — WhatIs.site",
    "url": `${siteUrl}/categories`,
    "description": "Browse all categories on WhatIs.site.",
    "numberOfItems": enrichedCategories.length
  })} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-12">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span class="mx-1">/</span>
        <span class="text-gray-900">Categories</span>
      </nav>
      <h1 class="font-heading text-4xl font-bold text-gray-900 mb-4">All Categories</h1>
      <p class="text-lg text-gray-600">
        Browse {allArticles.length.toLocaleString()} articles across {enrichedCategories.length} categories.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {enrichedCategories.map(cat => (
        <a
          href={`/category/${cat.slug}`}
          class="group block bg-white rounded-lg border border-gray-100 p-6 hover:shadow-md hover:border-blue-100 transition-all"
        >
          <h2 class="font-heading text-lg font-semibold text-gray-900 group-hover:text-primary transition-colors mb-2">
            {cat.label}
          </h2>
          <p class="text-sm text-gray-500 mb-3 line-clamp-2">{cat.description}</p>
          <span class="text-xs text-gray-400">{cat.count} articles</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
