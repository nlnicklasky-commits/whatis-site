---
import { getCollection } from 'astro:content';
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import categoriesData from '../../data/categories.json';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const categories = [...new Set(articles.map(a => a.data.category))];

  return categories.map(category => {
    const categoryArticles = articles
      .filter(a => a.data.category === category)
      .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime());

    const catInfo = categoriesData.find((c: any) => c.slug === category);
    const description = catInfo?.description ||
      `Explore our collection of articles about ${category.replace(/-/g, ' ')}.`;

    return {
      params: { category },
      props: { articles: categoryArticles, description },
    };
  });
}

const { category } = Astro.params;
const { articles, description } = Astro.props;
---

<CategoryLayout category={category!} description={description} articles={articles} />
